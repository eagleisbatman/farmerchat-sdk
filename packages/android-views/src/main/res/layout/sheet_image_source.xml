<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/fc_dark_surface"
    android:paddingHorizontal="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="24dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/fc_dark_text_muted"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/fc_add_image"
        android:textColor="@color/fc_dark_text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/fc_image_subtitle"
        android:textColor="@color/fc_dark_text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="24dp" />

    <!-- Options card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/fc_dark_card"
        android:layout_marginBottom="12dp">

        <!-- Take photo -->
        <LinearLayout
            android:id="@+id/btnTakePhoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_fc_camera"
                android:background="@drawable/fc_icon_circle_history"
                android:layout_marginEnd="14dp" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/fc_take_photo" android:textColor="@color/fc_dark_text_primary" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/fc_take_photo_desc" android:textColor="@color/fc_dark_text_secondary" android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/fc_dark_text_muted" android:alpha="0.2" />

        <!-- Gallery -->
        <LinearLayout
            android:id="@+id/btnChooseGallery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_fc_gallery"
                android:background="@drawable/fc_icon_circle_history"
                android:layout_marginEnd="14dp" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/fc_choose_gallery" android:textColor="@color/fc_dark_text_primary" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/fc_choose_gallery_desc" android:textColor="@color/fc_dark_text_secondary" android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnCancelImageSource"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/fc_cancel"
        android:textColor="@color/fc_dark_text_muted"
        android:background="@android:color/transparent" />

</LinearLayout>

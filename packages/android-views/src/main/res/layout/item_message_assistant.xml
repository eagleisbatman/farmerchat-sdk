<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/fc_padding_extra_small"
    android:paddingHorizontal="@dimen/fc_padding_small">

    <!-- FC Avatar -->
    <ImageView
        android:id="@+id/avatar"
        android:layout_width="@dimen/fc_avatar_size"
        android:layout_height="@dimen/fc_avatar_size"
        android:src="@android:drawable/sym_def_app_icon"
        android:contentDescription="@string/fc_assistant_avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Message card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_assistant_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/fc_padding_small"
        app:cardBackgroundColor="@color/fc_assistant_bubble"
        app:cardCornerRadius="@dimen/fc_bubble_corner_radius"
        app:cardElevation="0dp"
        app:layout_constraintStart_toEndOf="@id/avatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="0dp"
        app:layout_constraintWidth_percent="0.8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/fc_padding_medium">

            <!-- Markdown rendered text -->
            <org.digitalgreen.farmerchat.views.ui.views.MarkdownTextView
                android:id="@+id/markdown_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/fc_on_assistant_bubble"
                android:textSize="@dimen/fc_text_body"
                android:lineSpacingExtra="@dimen/fc_line_spacing" />

            <!-- Follow-up chips -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/follow_up_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/fc_padding_small"
                android:visibility="gone"
                app:chipSpacing="@dimen/fc_padding_extra_small"
                tools:visibility="visible" />

            <!-- Actions row: Listen + Copy -->
            <LinearLayout
                android:id="@+id/actions_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <!-- Listen pill button -->
                <LinearLayout
                    android:id="@+id/btn_listen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/fc_listen_pill_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/ic_listen"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_lock_silent_mode_off"
                        android:contentDescription="@null"
                        app:tint="@color/fc_primary" />

                    <TextView
                        android:id="@+id/tv_listen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Listen"
                        android:textColor="@color/fc_primary"
                        android:textSize="11sp"
                        android:textStyle="normal" />

                    <ProgressBar
                        android:id="@+id/progress_listen"
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:visibility="gone"
                        android:indeterminateTint="@color/fc_primary"
                        style="?android:attr/progressBarStyle" />
                </LinearLayout>

                <!-- Copy icon button -->
                <ImageButton
                    android:id="@+id/btn_copy"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="8dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:background="@drawable/fc_copy_btn_bg"
                    android:contentDescription="Copy response"
                    app:tint="@color/fc_text_secondary" />
            </LinearLayout>

            <!-- Feedback row -->
            <LinearLayout
                android:id="@+id/feedback_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/fc_padding_small"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btn_thumb_up"
                    android:layout_width="@dimen/fc_feedback_button_size"
                    android:layout_height="@dimen/fc_feedback_button_size"
                    android:src="@android:drawable/btn_star_big_on"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/fc_thumbs_up"
                    app:tint="@color/fc_text_secondary" />

                <ImageButton
                    android:id="@+id/btn_thumb_down"
                    android:layout_width="@dimen/fc_feedback_button_size"
                    android:layout_height="@dimen/fc_feedback_button_size"
                    android:layout_marginStart="@dimen/fc_padding_small"
                    android:src="@android:drawable/btn_star_big_off"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/fc_thumbs_down"
                    app:tint="@color/fc_text_secondary" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>

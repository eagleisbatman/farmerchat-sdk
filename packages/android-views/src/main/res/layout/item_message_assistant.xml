<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/fc_padding_extra_small"
    android:paddingHorizontal="@dimen/fc_padding_small">

    <!-- FC Avatar -->
    <ImageView
        android:id="@+id/avatar"
        android:layout_width="@dimen/fc_avatar_size"
        android:layout_height="@dimen/fc_avatar_size"
        android:src="@android:drawable/sym_def_app_icon"
        android:contentDescription="@string/fc_assistant_avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Message card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_assistant_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/fc_padding_small"
        app:cardBackgroundColor="@color/fc_assistant_bubble"
        app:cardCornerRadius="@dimen/fc_bubble_corner_radius"
        app:cardElevation="0dp"
        app:layout_constraintStart_toEndOf="@id/avatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="0dp"
        app:layout_constraintWidth_percent="0.8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/fc_padding_medium">

            <!-- Markdown rendered text -->
            <org.digitalgreen.farmerchat.views.ui.views.MarkdownTextView
                android:id="@+id/markdown_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/fc_on_assistant_bubble"
                android:textSize="@dimen/fc_text_body"
                android:lineSpacingExtra="@dimen/fc_line_spacing" />

            <!-- Follow-up chips -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/follow_up_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/fc_padding_small"
                android:visibility="gone"
                app:chipSpacing="@dimen/fc_padding_extra_small"
                tools:visibility="visible" />

            <!-- Feedback row -->
            <LinearLayout
                android:id="@+id/feedback_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/fc_padding_small"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btn_thumb_up"
                    android:layout_width="@dimen/fc_feedback_button_size"
                    android:layout_height="@dimen/fc_feedback_button_size"
                    android:src="@android:drawable/btn_star_big_on"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/fc_thumbs_up"
                    app:tint="@color/fc_text_secondary" />

                <ImageButton
                    android:id="@+id/btn_thumb_down"
                    android:layout_width="@dimen/fc_feedback_button_size"
                    android:layout_height="@dimen/fc_feedback_button_size"
                    android:layout_marginStart="@dimen/fc_padding_small"
                    android:src="@android:drawable/btn_star_big_off"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/fc_thumbs_down"
                    app:tint="@color/fc_text_secondary" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>

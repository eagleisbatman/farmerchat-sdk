<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center"
    android:padding="@dimen/fc_padding_small"
    android:background="@color/fc_warning_background">

    <ImageView
        android:layout_width="@dimen/fc_icon_small"
        android:layout_height="@dimen/fc_icon_small"
        android:src="@android:drawable/ic_dialog_alert"
        android:contentDescription="@string/fc_no_connection_icon"
        app:tint="@color/fc_warning" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/fc_padding_small"
        android:text="@string/fc_no_connection"
        android:textSize="@dimen/fc_text_caption"
        android:textColor="@color/fc_warning" />

</LinearLayout>

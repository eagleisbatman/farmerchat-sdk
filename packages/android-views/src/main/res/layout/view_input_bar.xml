<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="@dimen/fc_padding_small"
    android:background="@color/fc_surface">

    <ImageButton
        android:id="@+id/btn_camera"
        android:layout_width="@dimen/fc_icon_button_size"
        android:layout_height="@dimen/fc_icon_button_size"
        android:src="@android:drawable/ic_menu_camera"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/fc_camera"
        app:tint="@color/fc_text_secondary" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/edit_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginHorizontal="@dimen/fc_padding_small"
        android:hint="@string/fc_message_hint"
        android:inputType="textMultiLine|textCapSentences"
        android:maxLines="4"
        android:imeOptions="actionSend"
        android:background="@android:color/transparent"
        android:textSize="@dimen/fc_text_body"
        android:textColor="@color/fc_text_primary"
        android:textColorHint="@color/fc_text_hint" />

    <ImageButton
        android:id="@+id/btn_voice"
        android:layout_width="@dimen/fc_icon_button_size"
        android:layout_height="@dimen/fc_icon_button_size"
        android:src="@android:drawable/ic_btn_speak_now"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/fc_voice"
        app:tint="@color/fc_text_secondary" />

    <ImageButton
        android:id="@+id/btn_send"
        android:layout_width="@dimen/fc_icon_button_size"
        android:layout_height="@dimen/fc_icon_button_size"
        android:src="@android:drawable/ic_menu_send"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/fc_send"
        app:tint="@color/fc_primary" />

</LinearLayout>

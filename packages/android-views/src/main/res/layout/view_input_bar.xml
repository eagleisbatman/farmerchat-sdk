<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="14dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="12dp"
    android:background="@color/fc_dark_surface">

    <!-- Message text field — pill shape -->
    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/edit_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:hint="@string/fc_message_hint_crops"
        android:inputType="textMultiLine|textCapSentences"
        android:maxLines="4"
        android:imeOptions="actionSend"
        android:background="@drawable/fc_input_field_bg"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        android:textSize="@dimen/fc_text_body"
        android:textColor="@color/fc_dark_text_primary"
        android:textColorHint="@color/fc_dark_text_muted" />

    <!-- 10dp spacer -->
    <Space
        android:layout_width="10dp"
        android:layout_height="wrap_content" />

    <!-- Camera button — 40dp dark circle (hidden when text exists, managed by ChatFragment) -->
    <FrameLayout
        android:id="@+id/btn_camera_container"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/fc_camera_button_bg">
        <ImageButton
            android:id="@+id/btn_camera"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_fc_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/fc_camera"
            android:scaleType="center" />
    </FrameLayout>

    <Space
        android:layout_width="6dp"
        android:layout_height="wrap_content" />

    <!-- Voice button — 48dp green circle (primary action) -->
    <FrameLayout
        android:id="@+id/btn_voice_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/fc_mic_button_bg"
        android:elevation="4dp">
        <ImageButton
            android:id="@+id/btn_voice"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_fc_mic"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/fc_voice"
            android:scaleType="center" />
    </FrameLayout>

    <!-- Send button — 48dp green circle (replaces mic when text is present) -->
    <FrameLayout
        android:id="@+id/btn_send_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        android:background="@drawable/fc_mic_button_bg"
        android:elevation="4dp">
        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/fc_send"
            android:scaleType="center" />
    </FrameLayout>

</LinearLayout>

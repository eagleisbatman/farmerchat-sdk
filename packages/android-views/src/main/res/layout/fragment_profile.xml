<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fc_background">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/fc_toolbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/fc_padding_small"
        android:background="@color/fc_primary"
        android:elevation="@dimen/fc_elevation_small"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/fc_icon_button_size"
            android:layout_height="@dimen/fc_icon_button_size"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/fc_back"
            app:tint="@color/fc_on_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/fc_profile"
            android:textColor="@color/fc_on_primary"
            android:textSize="@dimen/fc_text_title"
            android:textStyle="bold"
            android:layout_marginStart="@dimen/fc_padding_small" />
    </LinearLayout>

    <!-- Language section title -->
    <TextView
        android:id="@+id/text_language_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/fc_language_setting"
        android:textSize="@dimen/fc_text_subtitle"
        android:textColor="@color/fc_text_primary"
        android:textStyle="bold"
        android:padding="@dimen/fc_padding_medium"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Language list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_languages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="@dimen/fc_padding_medium"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/text_language_title"
        app:layout_constraintBottom_toTopOf="@id/powered_by_footer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Powered by footer -->
    <TextView
        android:id="@+id/powered_by_footer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/fc_powered_by"
        android:textSize="@dimen/fc_text_caption"
        android:textColor="@color/fc_text_secondary"
        android:gravity="center"
        android:padding="@dimen/fc_padding_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
